{
  "name": "realtime-chat-application",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "start": "npm run start -w server",
    "seed": "npm run seed -w server",
    "test": "npm run test -w server && npm run lint -w client",
    "lint": "npm run lint -w client",
    "load:socket": "node load/socket-load.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "socket.io-client": "^4.8.1"
  }
}

